<Window x:Class="SharafutdinovK_Laba8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SharafutdinovK_Laba8"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Текущий инвентарь (Stack)" Foreground="White" Margin="5">
            <ListBox x:Name="InventoryList" Background="#1E1E1E" Foreground="LightGreen"/>
        </GroupBox>

        <GroupBox Header="История команд" Grid.Column="1" Foreground="White" Margin="5">
            <ListBox x:Name="HistoryList" Background="#1E1E1E" Foreground="LightGray"/>
        </GroupBox>

        <TextBox x:Name="CommandInput" Grid.Row="1" Grid.ColumnSpan="2" 
                 Margin="5" Height="30" VerticalContentAlignment="Center"
                 Background="#3C3C3C" Foreground="White" CaretBrush="White"
                 KeyDown="CommandInput_KeyDown" />
    </Grid>
</Window>
